# StrategyAI - Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# GROQ API (REQUIRED - Embedded Key for ALL Users)
# =============================================================================
# This key is used for "Local AI" mode - ALL users get free access through your key
# Get your free key at: https://console.groq.com/keys
# Free tier: 30 requests/min, 14,400 requests/day
# Users DO NOT need their own Groq key - yours covers everyone
GROQ_API_KEY=gsk-your-groq-api-key-here

# =============================================================================
# DeepSeek API (OPTIONAL - For Users Who Want Upgraded AI)
# =============================================================================
# Users can provide their own DeepSeek key for complex strategies
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Bitget API (for historical market data)
# Get your keys at: https://www.bitget.com/api
BITGET_API_KEY=your-bitget-api-key
BITGET_API_SECRET=your-bitget-api-secret

# Optional: Streamlit secrets (for deployment)
# STREAMLIT_SERVER_PORT=8501
