{
  "version": 2,
  "builds": [
    {
      "src": "requirements.txt",
      "use": "@vercel/python"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DEEPSEEK_API_KEY": "@deepseek-api-key",
    "BITGET_API_KEY": "@bitget-api-key",
    "BITGET_API_SECRET": "@bitget-api-secret"
  },
  "outputDirectory": ".vercel/output"
}
